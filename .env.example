# --- Live smoke (self-hosted runner; see docs/SMOKE.md) ---
# Host port for jellybot-dev during smoke (prod uses 8080).
# JELLYBOT_SMOKE_HOST_PORT=8093
# JELLYBOT_SMOKE_HEALTH_URL=http://127.0.0.1:8093/healthz
# JELLYBOT_SMOKE_LOG_CMD=docker logs jellybot-dev
# JELLYBOT_SMOKE_ITEM_ID=
# JELLYBOT_SMOKE_QUOTE_QUERY=arrested
# JELLYBOT_SMOKE_SERIES_QUERY=Simp
# JELLYBOT_SMOKE_LOG_POLL_SEC=45
# JELLYBOT_SMOKE_RETRY_COUNT=2

DISCORD_CLIENT_ID=
DISCORD_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated guild IDs for instant guild command sync (include every prod guild).
# IntroVRt Lounge: 1103814778616557638 | Bottitesto: 1291440813175341194
DISCORD_GUILD_IDS=

# Set to 1 in Cursor Cloud / CI so agents never open a second Discord gateway on the prod token.
# JELLYBOT_DISABLE_DISCORD_GATEWAY=1

JELLYFIN_URL=http://127.0.0.1:8096
JELLYFIN_USERNAME=
JELLYFIN_PASSWORD=
JELLYFIN_MOVIES_LIBRARY_ID=
JELLYFIN_TV_LIBRARY_ID=

MAX_CLIP_SECONDS=180
MAX_CLIP_MB=9
HEALTH_PORT=8080
APP_VERSION=dev

SUBTITLE_DB_PATH=/var/lib/jellybot/data/subtitles.db
SUBTITLE_LANGUAGES=eng,en
# Clip audio track preference (defaults to SUBTITLE_LANGUAGES)
# AUDIO_LANGUAGES=eng,en
SUBTITLE_DEFAULT_CLIP_SECONDS=15
SUBTITLE_QUOTE_PADDING_SECONDS=2
SUBTITLE_INDEX_CONCURRENCY=4
SUBTITLE_INDEX_ON_STARTUP=incremental

# /supercut feature (#140) - hard caps so it can't melt the box.
# SUPERCUT_MAX_CLIPS=30
# SUPERCUT_MAX_DURATION_SECONDS=90
# SUPERCUT_PADDING_MS=400
# SUPERCUT_COALESCE_GAP_MS=1500
# SUPERCUT_MAX_MB=24

JELLYBOT_CLIP_DIR=/var/lib/jellybot/clips
# Host bind mount for subtitle index DB (default ./data in repo checkout)
# JELLYBOT_DATA_HOST_DIR=/home/heavygee/docker/jellybot/data
CLIP_AUTOCOMPLETE_MAX_CONCURRENT=3

# --- Production release announce (on_ready one-shot; see docs/architecture.md) ---
# GITHUB_TOKEN=
# NOTIFICATION_CHANNEL_ID=1159798255295660103   # prod (IntroVRt Lounge)
# NOTIFICATION_CHANNEL_ID=1291442908821454959   # dev bot (Bottitesto)
# RELEASE_REPO=introVRt-Lounge/jellybot
# OPENAI_API_KEY=
# Used by /feature suggest scope gate (gpt-4o-mini) and release note summaries when set.
# RELEASE_ANNOUNCE_GRACE_MS=60000
# BOT_STATE_DB_PATH=/var/lib/jellybot/data/bot-state.db

# --- Feature suggestions (Discord rank + triage) ---
# User-facing cards + leaderboard only — not pipeline ops alerts.
# FEATURE_SUGGESTIONS_CHANNEL_ID=
# Maintainer pipeline stuck/failed alerts (IntroVRt #botspam):
# DISCORD_BOTSPAM_CHANNEL_ID=1164501234271653918
# Radgey, HeavyGee, Ariabel (comma-separated Discord user snowflakes)
# FEATURE_TRIAGE_DISCORD_USER_IDS=563807698223890442,475110314611048461,724384676780966020

# --- Quote request acquisition (issue #97 Phase 1) ---
# When set, /quote's "Can't find it? Submit a request" modal will auto-add missing movies
# to Radarr. Without these, the bot falls back to a passive watch-and-notify mode.
# RADARR_URL=http://127.0.0.1:7878/radarr
# RADARR_API_KEY=
# Optional override; otherwise auto-picks "HD-1080p (no 4K)" or first 1080p profile.
# RADARR_QUALITY_PROFILE_ID=10
# Optional override; otherwise auto-picks the first accessible root folder.
# RADARR_ROOT_FOLDER_PATH=/data/movies
# Refuse requests when the chosen root folder has less free space than this (default 3 GB).
# RADARR_MIN_FREE_GB=3

# --- Quote request acquisition: TV episodes (issue #116 Phase 2 V1) ---
# When set, /quote's "Can't find it?" -> TV path adds the show to Sonarr unmonitored
# and selectively monitors+searches a single user-supplied (Season, Episode).
# SONARR_URL=http://127.0.0.1:8989/sonarr
# SONARR_API_KEY=
# Optional quality profile override; otherwise auto-picks 1080p variants.
# SONARR_QUALITY_PROFILE_ID=
# Optional language profile override (older Sonarr v3 only; newer Sonarr versions ignore).
# SONARR_LANGUAGE_PROFILE_ID=
# Optional root folder override; otherwise auto-picks the first accessible root.
# SONARR_ROOT_FOLDER_PATH=/data/tv
# Refuse TV requests when the chosen root folder has less free space than this (default 3 GB).
# SONARR_MIN_FREE_GB=3
# Comma-separated case-insensitive substrings that will skip a Sonarr root folder during
# default selection. Use to keep the request flow off special-purpose libraries.
# SONARR_EXCLUDED_ROOT_KEYWORDS=

# --- Optional subtitle gap-fill (planned; see docs/caps-and-limits.md) ---
# OpenSubtitles.org API: https://www.opensubtitles.com/en/consumers
# OPENSUBTITLES_ENABLED=false
# OPENSUBTITLES_API_KEY=
# OPENSUBTITLES_USERNAME=
# OPENSUBTITLES_PASSWORD=

# Whisper / STT long-tail: OpenAI-compatible POST /v1/audio/transcriptions
# This infra: local-speech-agent gateway http://127.0.0.1:18008 (preferred)
# WHISPER_LONG_TAIL_ENABLED=false
# WHISPER_STT_URL=http://127.0.0.1:18008/v1/audio/transcriptions
# WHISPER_STT_MODEL=Systran/faster-whisper-large-v3

# --- Event-driven indexer kick (issue #122) ---
# When set, jellybot exposes /hooks/{radarr,sonarr,bazarr} on the health port and
# triggers a single-item incremental index whenever Connect notifies us of a new
# file or subtitle drop. Inside Docker the URL is http://jellybot:8080/hooks/<source>?token=<secret>.
# Leave WEBHOOK_SHARED_SECRET unset to disable the entire surface.
# WEBHOOK_SHARED_SECRET=
# Coalesce window in seconds for repeated webhooks against the same item (default 30).
# WEBHOOK_DEBOUNCE_SECONDS=30
# Cap on poll-for-item retries before giving up waiting on Jellyfin (default 12).
# WEBHOOK_POLL_MAX_ATTEMPTS=12
# Poll interval between item-lookup retries, in seconds (default 10 - so default total wait is 12 * 10s = 2 min).
# WEBHOOK_POLL_INTERVAL_SECONDS=10

# Optional: bind-mount host path for ephemeral clip files instead of the jellybot-clips volume
# JELLYBOT_CLIP_HOST_DIR=
