{
  "name": "jellybot",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "register-commands": "bun run src/register-commands.ts",
    "index-subtitles": "bun run src/cli/index-subtitles.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci": "bun run typecheck && bun test",
    "smoke:discord": "PYTHONPATH=${DISCORD_PY_SELF_ROOT:?Set DISCORD_PY_SELF_ROOT to discord.py-self checkout} python3 scripts/discord-clip-smoke.py",
    "secrets:staged": "./scripts/gitleaks-staged.sh",
    "prepare": "husky || true"
  },
  "dependencies": {
    "discord.js": "^14.19.2",
    "dotenv": "^17.4.2",
    "node-webvtt": "^1.9.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  }
}
